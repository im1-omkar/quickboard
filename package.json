{
  "name": "quickboard",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "turbo": "^2.10.0",
    "typescript": "5.9.2",
    "@types/bun": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "module": "index.ts",
  "type": "module"
}
